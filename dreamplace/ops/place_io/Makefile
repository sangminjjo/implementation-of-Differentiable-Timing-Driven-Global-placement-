src/place_io.i: src/place_io.cpp.i
.PHONY : src/place_io.i

# target to preprocess a source file
src/place_io.cpp.i:
	cd /DREAMPlace && $(MAKE) $(MAKESILENT) -f dreamplace/ops/place_io/CMakeFiles/place_io_cpp.dir/build.make dreamplace/ops/place_io/CMakeFiles/place_io_cpp.dir/src/place_io.cpp.i
.PHONY : src/place_io.cpp.i

src/place_io.s: src/place_io.cpp.s
